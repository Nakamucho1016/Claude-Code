# Required: Anthropic API key for article generation
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx

# Optional: Claude model to use (default: claude-haiku-4-5-20251001)
# MATOME_MODEL=claude-haiku-4-5-20251001

# Optional: Maximum articles per run (default: 5)
# MATOME_LIMIT=5

# Optional: Site base URL for OGP tags (default: https://example.github.io/matome)
# MATOME_SITE_URL=https://yourusername.github.io/your-repo

# Optional: Site title (default: 今日のトレンドまとめ)
# MATOME_SITE_TITLE=今日のトレンドまとめ
